TEST_FLAG_RVC ?= 0
TEST_FLAG_PAD2B ?= 1
TEST_FLAG_PAGE1_EXEC ?= 1
TEST_FLAG_PAGE2_EXEC ?= 1
TEST_FLAG_PAGE1_IO ?= 0
TEST_FLAG_PAGE2_IO ?= 0

NAME_SUFFIX :=

ifeq ($(TEST_FLAG_RVC),1)
NAME_SUFFIX := $(NAME_SUFFIX)_rvc
endif

ifeq ($(TEST_FLAG_PAD2B),1)
NAME_SUFFIX := $(NAME_SUFFIX)_pad2b
endif

NAME_SUFFIX := $(NAME_SUFFIX)_page1
ifeq ($(TEST_FLAG_PAGE1_EXEC),1)
NAME_SUFFIX := $(NAME_SUFFIX)_exec
endif
ifeq ($(TEST_FLAG_PAGE1_IO),1)
NAME_SUFFIX := $(NAME_SUFFIX)_io
endif
ifeq ($(TEST_FLAG_PAGE1_EXEC)$(TEST_FLAG_PAGE1_IO),00)
NAME_SUFFIX := $(NAME_SUFFIX)_none
endif

NAME_SUFFIX := $(NAME_SUFFIX)_page2
ifeq ($(TEST_FLAG_PAGE2_EXEC),1)
NAME_SUFFIX := $(NAME_SUFFIX)_exec
endif
ifeq ($(TEST_FLAG_PAGE2_IO),1)
NAME_SUFFIX := $(NAME_SUFFIX)_io
endif
ifeq ($(TEST_FLAG_PAGE2_EXEC)$(TEST_FLAG_PAGE2_IO),00)
NAME_SUFFIX := $(NAME_SUFFIX)_none
endif

NAME = crosspage$(NAME_SUFFIX)
SRCS = crosspage.c
DST_DIR = $(APP_DIR)/build/$(ARCH)/$(NAME_SUFFIX)/

CPPFLAGS += -DTEST_FLAG_RVC=$(TEST_FLAG_RVC)
CPPFLAGS += -DTEST_FLAG_PAGE1_EXEC=$(TEST_FLAG_PAGE1_EXEC)
CPPFLAGS += -DTEST_FLAG_PAGE2_EXEC=$(TEST_FLAG_PAGE2_EXEC)
CPPFLAGS += -DTEST_FLAG_PAGE1_IO=$(TEST_FLAG_PAGE1_IO)
CPPFLAGS += -DTEST_FLAG_PAGE2_IO=$(TEST_FLAG_PAGE2_IO)
CPPFLAGS += -DTEST_FLAG_PAD2B=$(TEST_FLAG_PAD2B)
LDFLAGS += -T $(APP_DIR)/crosspage.ld
include $(AM_HOME)/Makefile.app
